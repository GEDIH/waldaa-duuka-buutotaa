# WDB Membership System — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit real credentials to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wdb_membership
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/wdb-website
APP_TIMEZONE=Africa/Addis_Ababa

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@wdb.org
SMTP_FROM_NAME=Waldaa Duuka Bu'ootaa

# ── Security ──────────────────────────────────────────────────────────────────
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_SECONDS=900
